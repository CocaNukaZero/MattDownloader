ditiveBackground":567794229,"textPrimary":4282072068,"textSecondary":4287599127,"invertedBackground":4285888531,"overlayBackground":3426434052},"darkThemeColorPalette":{"baseBackground":4280098305,"raisedBackground":4282072068,"additiveBackground":735566389,"textPrimary":4294835677,"textSecondary":4293980823,"invertedBackground":4293388663,"overlayBackground":3426434052},"enableColorSampledText":true}},{"viewCountFactoidRenderer":{"viewCountEntityKey":"EgtQc1huZ2J3b3VaTSDCASgB","factoid":{"factoidRenderer":{"value":{"simpleText":"36,645"},"label":{"simpleText":"Views"},"accessibilityText":"36,645 views","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4294967280,"raisedBackground":4294967280,"additiveBackground":567794229,"textPrimary":4282072068,"textSecondary":4287599127,"invertedBackground":4285888531,"overlayBackground":3426434052},"darkThemeColorPalette":{"baseBackground":4280098305,"raisedBackground":4282072068,"additiveBackground":735566389,"textPrimary":4294835677,"textSecondary":4293980823,"invertedBackground":4293388663,"overlayBackground":3426434052},"enableColorSampledText":true}},"viewCountType":"VIEW_COUNT_FACTOID_TYPE_TOTAL_VIEWS"}},{"factoidRenderer":{"value":{"simpleText":"May 11"},"label":{"simpleText":"2026"},"accessibilityText":"May 11, 2026","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4294967280,"raisedBackground":4294967280,"additiveBackground":567794229,"textPrimary":4282072068,"textSecondary":4287599127,"invertedBackground":4285888531,"overlayBackground":3426434052},"darkThemeColorPalette":{"baseBackground":4280098305,"raisedBackground":4282072068,"additiveBackground":735566389,"textPrimary":4294835677,"textSecondary":4293980823,"invertedBackground":4293388663,"overlayBackground":3426434052},"position":"FACTOID_POSITION_LAST","enableColorSampledText":true}}],"channelNavigationEndpoint":{"clickTrackingParams":"CBQQ040EGAciEwj96I3Ps7aUAxVMjdQCHcbmPArKAQTfe-I4","commandMetadata":{"webCommandMetadata":{"url":"/@zWORMzGaming","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCYcVUqtQ0Bjl_h9qyWu969Q","canonicalBaseUrl":"/@zWORMzGaming"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/ytc/AIdro_myoTEfz6ZoOGkdly8gdXkF3z192AJMOHQe5gBtJYv98AU=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"Testing the GTX 1630 4GB GPU Cyberpunk 2077 at 720p, 1080p, 1440p and 4K, using the minimum and, low and ultra settings, FSR, XeSS and Frame Generation!\n\n⏱ Timestamps ⏱\n\nIntro, Specs, Stuff - 0:00\n1080p Lowest - 0:49\n1080p Lowest / FSR Q - 3:57\n1080p Lowest / FSR B - 9:59\n1080p Lowest / FSR P - 11:12\n1080p Low - 13:07\n1080p Low / FSR Q - 15:05\n720p Low - 15:38\n720p Lowest - 17:47\n1440p Lowest - 19:25\n1440p Lowest / FSR P - 20:25\n1440p Lowest / XeSS B - 21:10\n1080p Lowest / XeSS UQ - 21:36\n4K Lowest - 22:32\n4K Lowest / FSR P - 23:15\n4K Lowest / XeSS UP - 23:48\n4K Ultra - 24:21\n1080p Lowest - 25:17\n1080p Lowest / FG - 25:55\n1080p Lowest / FSR Q / FG - 26:53 \n1080p Lowest / FSR P / FG - 27:31\n1080p Ultra / FG - 29:05\n4K Ultra / FG - 29:32\n\nGTX 1630 Full Review -    • GTX 1630 - Nvidia's Biggest Flop...  \n\n🔧SPECS🔧\n\n◾️ CPU - Intel Core i5 12600KF @5.1GHz\n◾️ Cooler - Lian Li Galahad Trinity II 240mm\n◾️ Nvidia GeForce GTX 1630 4GB - MSI Aero\n◾️ RAM - 32GB DDR5 6000MHz (2x16GB CL36)\n◽️ OS - Windows 11 Pro\n◽️ SSD - Lexar PCIe 4.0 2TB (game installed here)\n◾️ Motherboard - Asus Prime Z690-P\n◾️ PSU - Corsair RM850e\n◾️ Case - Deepcool CH510\n\n🎥 Recorded with a capture card and another PC for no FPS loss.\n\n------------------------------------------------------------------------\n\nSecond Channel: ‪@KryzzpDigimoon‬ \n\n▶️ More videos like this -    • ⭐ PC Hardware Reviews  \n\n🟢 GTX 1630 Playlist -    • 🟢 GTX 1630  \n\n#rtxoff\n#gtx1630 \n#nvidia\n#gtxon \n#cyberpunk2077 \n#cp2077 \n#pcgaming \n\n------------------------------------------------------------------------\n\n📸 zWORMz Instagram:   / zwormz.gaming  \n\n🔉 And join our Discord!   / discord  ","commandRuns":[{"startIndex":192,"length":4,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBQQ040EGAciEwj96I3Ps7aUAxVMjdQCHcbmPArKAQTfe-I4","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=PsXngbwouZM","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"PsXngbwouZM","continuePlayback":true,"startTimeSeconds":0,"watchEndpointSupportedOnesieConfig":{"html5PlaybackOnesieConfig":{"commonConfig":{"url":"https://rr1---sn-vgqskn6y.googlevideo.com/initplayback?source=youtube\u0026oeis=1\u0026c=WEB\u0026oad=3200\u0026ovd=3200\u0026oaad=11000\u0026oavd=11000\u0026ocs=700\u0026oewis=1\u0026oputc=1\u0026ofpcc=1\u0026msp=1\u0026odepv=1\u0026id=3ec5e781bc28b993\u0026ip=52.162.137.101\u0026initcwndbps=3271250\u0026mt=1778679706\u0026oweuc="}}}}}},"onTapOptions":{"accessibilityInfo":{"accessibilityLabel":"0 seconds"}}},{"startIndex":212,"length":4,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBQQ040EGAciEwj96I3Ps7aUAxVMjdQCHcbmPArKAQTfe-I4","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=PsXngbwouZM\u0026t=49s","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"PsXngbwouZM","continuePlayback":true,"startTimeSeconds":49,"watchEndpointSupportedOnesieConfig":{"html5PlaybackOnesieConfig":{"commonConfig":{"url":"https://rr1---sn-vgqskn6y.googlevideo.com/initplayback?source=youtube\u0026oeis=1\u0026c=WEB\u0026oad=3200\u0026ovd=3200\u0026oaad=11000\u0026oavd=11000\u0026ocs=700\u0026oewis=1\u0026oputc=1\u0026ofpcc=1\u0026msp=1\u0026odepv=1\u0026id=3ec5e781bc28b993\u0026ip=52.162.137.101\u0026osts=49\u0026initcwndbps=3271250\u0026mt=1778679706\u00